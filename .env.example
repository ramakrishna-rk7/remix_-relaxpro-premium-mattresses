# Example .env file

# The frontend passes this API key in API requests to the backend.
# The backend uses it to authenticate calls to the Gemini API.
GEMINI_API_KEY=""

# The backend URL is automatically injected at runtime.
BACKEND_URL=""

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Sheets Spreadsheet integration Apps Script deployment URL (Web App)
# Used on the client side to submit lead form details and COD orders.
VITE_PUBLIC_GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/AKfycbweoqpHPwykNsd_pK_bhyR_V5QRBTdYUa22cRWfSbLYusViz7MogttuMKw8_k-B-KLZ/exec"
